// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String   @id @default(cuid())
  name      String   @default("Francis Kossyrisochukwu Uzoigwe")
  bio       String   @default("Software Engineer")
  email     String   @default("kossyuzoigwe@gmail.com")
  location  String   @default("Lagos, Nigeria")
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  index       String
  title       String
  category    String
  description String
  content     String // Markdown for detailed page
  tech        String[]
  link        String?
  image       String?
  color       String   @default("bg-white")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Blog {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String
  content   String // Markdown
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  label     String
  href      String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}
